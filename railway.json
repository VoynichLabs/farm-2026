{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "node .next/standalone/server.js",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  },
  "nixpacks": {
    "providers": ["nodejs"]
  },
  "env": {
    "NODE_ENV": "production"
  }
}
